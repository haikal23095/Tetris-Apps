{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with basic information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "lastLogin"]
    },
    "HighScore": {
      "title": "High Score",
      "description": "A single high score entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "score": { "type": "integer" },
        "level": { "type": "integer" },
        "lines": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "score", "level", "lines", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/leaderboard/{scoreId}": {
      "schema": "HighScore",
      "description": "Global leaderboard entries"
    }
  }
}
